          ]
        }
      },
      "response": []
    },
    {
      "name": "create-user",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// limpa estado antigo de todos os escopos antes de qualquer coisa\r",
              "pm.collectionVariables.unset(\"apiKey\");\r",
              "pm.environment.unset(\"apiKey\");\r",
              "\r",
              "pm.test(\"user created 201\", () => pm.response.to.have.status(201));"
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"login\": \"user\",\r\n    \"password\": \"123456\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/user",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "user"
          ]
        }
      },
      "response": []
    },
    {
      "name": "try-login",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// garante escopo limpo antes do login\r",
              "pm.collectionVariables.unset(\"apiKey\");\r",
              "pm.environment.unset(\"apiKey\");"
            ],
            "type": "text/javascript",
            "packages": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.collectionVariables.unset(\"apiKey\");\r",
              "pm.environment.unset(\"apiKey\");\r",
              "\r",
              "pm.test(\"login 200\", () => pm.response.to.have.status(200));\r",
              "\r",
              "const responseData = pm.response.json();\r",
              "\r",
              "pm.test(\"apiKey presente e no formato correto\", () => {\r",
              "    pm.expect(responseData).to.have.property(\"apiKey\");\r",
              "    pm.expect(responseData.apiKey).to.be.a(\"string\");\r",
              "    pm.expect(responseData.apiKey.split(\".\").length).to.eql(2);\r",
              "    pm.expect(responseData.apiKey.split(\".\")[0]).to.not.be.empty;\r",
              "    pm.expect(responseData.apiKey.split(\".\")[1]).to.not.be.empty;\r",
              "});\r",
              "\r",
              "pm.collectionVariables.set(\"apiKey\", responseData.apiKey);\r",
              "console.log(\"apiKey salva:\", responseData.apiKey);"
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "basic",
          "basic": [
            {
              "key": "username",
              "value": "user",
              "type": "string"
            },
            {
              "key": "password",
              "value": "123456",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "try-get-sensitive",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// valida que a variável existe, não está vazia e está no formato certo\r",
              "const key = pm.collectionVariables.get(\"apiKey\");\r",
              "\r",
              "if (!key || key.trim() === \"\" || key.split(\".\").length !== 2) {\r",
              "    throw new Error(\r",
              "        \"apiKey inválida ou ausente na collection. \" +\r",
              "        \"Rode POST /login antes. Valor atual: [\" + key + \"]\"\r",
              "    );\r",
              "}\r",
              "\r",
              "// protege contra variável de environment sobrescrevendo\r",
              "pm.environment.unset(\"apiKey\");\r",
              "\r",
              "console.log(\"apiKey resolvida:\", key);"
            ],
            "type": "text/javascript",
            "packages": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"sensitive 200\", () => pm.response.to.have.status(200));"
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "GET",
